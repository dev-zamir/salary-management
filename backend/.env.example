# Copy this file to .env and fill in the values for your local environment.
# .env is gitignored — never commit real credentials.

# PostgreSQL connection
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# CORS — comma-separated list of origins allowed to call the API.
# Leave unset in environments where cross-origin access should be denied.
# Example for multiple: "http://localhost:5173,https://app.example.com"
CORS_ALLOWED_ORIGINS=http://localhost:5173
